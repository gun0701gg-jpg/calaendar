rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthor(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 팀 일정 (1차 개발 범위)
    // - 직접 등록한 일정(importBatch 없음)은 작성자 본인만 수정/삭제
    // - 엑셀로 올린 근무현황(importBatch 있음)은 팀 공용 데이터라 로그인한 누구나 재업로드 시 교체 가능
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        isAuthor(resource.data.authorUid) || resource.data.importBatch is string
      );
    }

    // 메모 (향후 확장) - 일정과 동일한 소유권 규칙
    match /memos/{memoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAuthor(resource.data.authorUid);
    }

    // 재고 관리 (향후 확장) - 팀 공용 자원이라 로그인 사용자 전체 편집 허용
    match /inventory/{itemId} {
      allow read, write: if isSignedIn();
    }

    // 입소상담 - 여러 직원이 이어서 상담할 수 있도록 팀 전체가 읽고 쓸 수 있는 공용 데이터
    match /consultations/{consultationId} {
      allow read, write: if isSignedIn();

      // 상담이력(로그)은 누적 기록이라 새로 남기는 것만 허용하고, 남긴 내용은 그대로 보존한다
      match /logs/{logId} {
        allow read, create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // 그 외 모든 문서는 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
