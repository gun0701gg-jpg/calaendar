rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthor(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 팀 일정 (1차 개발 범위)
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAuthor(resource.data.authorUid);
    }

    // 메모 (향후 확장) - 일정과 동일한 소유권 규칙
    match /memos/{memoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAuthor(resource.data.authorUid);
    }

    // 재고 관리 (향후 확장) - 팀 공용 자원이라 로그인 사용자 전체 편집 허용
    match /inventory/{itemId} {
      allow read, write: if isSignedIn();
    }

    // 그 외 모든 문서는 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
